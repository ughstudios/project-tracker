// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("EMPLOYEE")
  approvalStatus String @default("APPROVED")
  approvedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedIssues Issue[] @relation("IssueAssignee")
  createdIssues  Issue[] @relation("IssueReporter")
  issueThreadEntries IssueThreadEntry[] @relation("IssueThreadAuthor")
  uploadedProjectAttachments ProjectAttachment[] @relation("ProjectAttachmentUploader")
  uploadedCustomerAttachments CustomerAttachment[] @relation("CustomerAttachmentUploader")
  uploadedIssueAttachments   IssueAttachment[]   @relation("IssueAttachmentUploader")
  uploadedIssueThreadAttachments IssueThreadAttachment[] @relation("IssueThreadAttachmentUploader")
  projectNotes               ProjectNote[]       @relation("ProjectNoteAuthor")
  auditLogs                  AuditLog[]          @relation("AuditLogActor")
  workRecords                WorkRecord[]
}

model WorkRecord {
  id        String   @id @default(cuid())
  workDate  DateTime
  title     String   @default("")
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, workDate])
}

model Customer {
  id        String   @id @default(cuid())
  name      String   @unique
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects    Project[]
  issues      Issue[]
  attachments CustomerAttachment[]
}

model Project {
  id        String   @id @default(cuid())
  name      String   @unique
  product   String
  archivedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  issues              Issue[]
  processorConfigs    ProjectProcessorConfig[]
  receiverCardConfigs ProjectReceiverCardConfig[]
  otherProductConfigs ProjectOtherProductConfig[]
  attachments         ProjectAttachment[]
  notes               ProjectNote[]
}

model ProjectProcessorConfig {
  id        String   @id @default(cuid())
  model     String
  firmware  String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectReceiverCardConfig {
  id        String   @id @default(cuid())
  model     String
  version   String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectOtherProductConfig {
  id        String   @id @default(cuid())
  category  String
  model     String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum WarehouseItemKind {
  PROCESSOR
  RECEIVER_CARD
  OTHER
}

/// On-hand warehouse stock for processors, receiver cards, and other products (same dimensions as project wizard).
model WarehouseStockLine {
  id              String            @id @default(cuid())
  kind            WarehouseItemKind
  model           String
  firmware        String            @default("")
  receiverVersion String            @default("")
  category        String            @default("")
  quantity        Int
  notes           String?
  location        String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@unique([kind, model, firmware, receiverVersion, category])
  @@index([kind])
}

model ProjectAttachment {
  id         String   @id @default(cuid())
  fileName   String
  fileUrl    String
  fileType   String
  fileSize   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectId  String
  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploaderId String?
  uploader   User?    @relation("ProjectAttachmentUploader", fields: [uploaderId], references: [id], onDelete: SetNull)
}

model CustomerAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  uploaderId String?
  uploader   User?    @relation("CustomerAttachmentUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([customerId])
}

model ProjectNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User    @relation("ProjectNoteAuthor", fields: [authorId], references: [id], onDelete: Restrict)
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  actorId String?
  actor   User?   @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model Issue {
  id             String   @id @default(cuid())
  title          String
  status         String   @default("OPEN")
  symptom        String
  cause          String
  solution       String
  rndContact     String
  doneAt         DateTime?
  archivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  projectId      String?
  customerId     String?
  assigneeId     String?
  reporterId     String

  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  customer  Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  assignee  User?   @relation("IssueAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter  User    @relation("IssueReporter", fields: [reporterId], references: [id], onDelete: Restrict)
  threadEntries IssueThreadEntry[]
  attachments   IssueAttachment[]
}

model IssueThreadEntry {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issueId  String
  issue    Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("IssueThreadAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  attachments IssueThreadAttachment[]
}

model IssueAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issueId    String
  issue      Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  uploaderId String?
  uploader   User?  @relation("IssueAttachmentUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([issueId])
}

model IssueThreadAttachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  fileSize  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  threadEntryId String
  threadEntry   IssueThreadEntry @relation(fields: [threadEntryId], references: [id], onDelete: Cascade)
  uploaderId    String?
  uploader      User?            @relation("IssueThreadAttachmentUploader", fields: [uploaderId], references: [id], onDelete: SetNull)

  @@index([threadEntryId])
}
