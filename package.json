{
  "name": "issue-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/vercel-build.mjs",
    "start": "next start",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.mjs",
    "neon:auth": "npx neonctl@latest auth",
    "neon:create": "npx neonctl@latest projects create --name project-tracker --region-id aws-us-east-1 --set-context",
    "neon:url": "npx neonctl@latest connection-string main --prisma --pooled",
    "neon:init": "npx neonctl@latest init --agent cursor"
  },
  "dependencies": {
    "@prisma/client": "6.16.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "next": "16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "6.16.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
