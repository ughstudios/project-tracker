# PostgreSQL (Neon, Supabase, or local). Use ?sslmode=require for Neon if needed.
# Neon via CLI (after `npm run neon:auth`): create project, then `npm run neon:url` and paste here.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
# Optional: non-pooled Postgres URL for Prisma migrations. If unset, Prisma uses DATABASE_URL.
# With Neon + pooled DATABASE_URL (host contains `-pooler`), set this to the non-pooled URI to avoid P1002 on migrate.
# DATABASE_DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Auth.js / NextAuth v5 — required in production (generate: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Public URL of the app (no trailing slash). After first Vercel deploy, set to your production URL.
AUTH_URL="https://your-project.vercel.app"

# Optional; some tooling still reads this
NEXTAUTH_URL="https://your-project.vercel.app"

# Vercel Blob — required for uploads when deployed on Vercel (VERCEL=1). Optional locally (uses public/uploads).
# After `vercel link`, run `vercel env pull` to fill .env.local (including this token).
# Connect the store to your Vercel *project* so this is set (store ID / region in UI are not used by the app).
# BLOB_READ_WRITE_TOKEN=""

# Blob access defaults to private (matches typical Vercel private stores). Set both to `public` only if
# your Blob store is public and you want direct URLs in the browser (no /api/blob/media).
# BLOB_STORE_ACCESS=public
# NEXT_PUBLIC_BLOB_STORE_ACCESS=public

# Optional: same deployment on Vercel’s default host (https://your-project.vercel.app, no trailing slash).
# Shown in upload errors so users on a *custom domain* can try large files where Blob client CORS works.
# NEXT_PUBLIC_VERCEL_APP_ORIGIN="https://your-project.vercel.app"

# Vercel AI Gateway: AI assistant + issue/thread EN↔ZH translation (recommended on Vercel).
# https://vercel.com/docs/ai-gateway/getting-started/text
# AI_GATEWAY_API_KEY=""
# AI_CHAT_MODEL="gpt-5.4"
# OPENAI_TRANSLATION_MODEL="gpt-4o-mini"
#
# Optional fallback for translation only: direct OpenAI API (no gateway). Ignored if AI_GATEWAY_API_KEY is set.
# AI_KEY=""
# OPENAI_API_KEY=""

# Vercel / Redis: caches identical translation payloads (SHA key) to cut model cost. Optional.
# REDIS_URL=""
# TRANSLATION_REDIS_TTL_SEC="7776000"
